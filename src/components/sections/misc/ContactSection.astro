---
// Import the necessary dependencies.
import AuthBtn from "@components/ui/buttons/AuthBtn.astro";
import ContactIconBlock from "@components/ui/blocks/ContactIconBlock.astro";
import TextInput from "@components/ui/forms/input/TextInput.astro";
import EmailContactInput from "@components/ui/forms/input/EmailContactInput.astro";
import PhoneInput from "@components/ui/forms/input/PhoneInput.astro";
import TextAreaInput from "@components/ui/forms/input/TextAreaInput.astro";
import SelectInput from "@components/ui/forms/input/SelectInput.astro";
import Icon from "@components/ui/icons/Icon.astro";
import { companyDetails } from "@data/new_content";

const title = "Get in Touch";
const subtitle =
  "Partner with India's leading earthing and lightning protection specialists. Our team is ready to support your project.";
---

<!-- Contact Section -->
<section class="relative py-16 lg:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span
        class="inline-block px-4 py-1.5 mb-4 text-sm font-semibold text-blue-600 dark:text-blue-400 bg-blue-100 dark:bg-blue-900/30 rounded-full"
      >
        Contact Us
      </span>
      <h1
        class="text-3xl md:text-4xl lg:text-5xl font-bold text-neutral-900 dark:text-neutral-100 mb-4"
      >
        {title}
      </h1>
      <p class="text-lg text-neutral-600 dark:text-neutral-400">
        {subtitle}
      </p>
    </div>

    <div class="grid lg:grid-cols-3 gap-8 lg:gap-12">
      <!-- Contact Information Sidebar -->
      <div class="lg:col-span-1 space-y-6">
        <!-- Quick Contact Cards -->
        <div
          class="bg-white dark:bg-neutral-800 rounded-2xl p-6 border border-neutral-200 dark:border-neutral-700 shadow-sm hover:shadow-lg transition-shadow"
        >
          <div class="flex items-start gap-4">
            <div
              class="flex-shrink-0 w-12 h-12 bg-blue-100 dark:bg-blue-900/30 rounded-xl flex items-center justify-center text-blue-600 dark:text-blue-400"
            >
              <Icon name="chatBubble" />
            </div>
            <div class="flex-1">
              <h3 class="font-bold text-neutral-900 dark:text-neutral-100 mb-1">
                Call or WhatsApp
              </h3>
              <p class="text-sm text-neutral-600 dark:text-neutral-400 mb-3">
                Get instant support
              </p>
              <a
                href={`tel:${companyDetails.phone}`}
                class="text-blue-600 dark:text-blue-400 font-semibold hover:underline"
              >
                {companyDetails.phone}
              </a>
            </div>
          </div>
        </div>

        <div
          class="bg-white dark:bg-neutral-800 rounded-2xl p-6 border border-neutral-200 dark:border-neutral-700 shadow-sm hover:shadow-lg transition-shadow"
        >
          <div class="flex items-start gap-4">
            <div
              class="flex-shrink-0 w-12 h-12 bg-blue-100 dark:bg-blue-900/30 rounded-xl flex items-center justify-center text-blue-600 dark:text-blue-400"
            >
              <Icon name="envelopeOpen" />
            </div>
            <div class="flex-1">
              <h3 class="font-bold text-neutral-900 dark:text-neutral-100 mb-1">
                Email Us
              </h3>
              <p class="text-sm text-neutral-600 dark:text-neutral-400 mb-3">
                For quotations & tenders
              </p>
              <a
                href={`mailto:${companyDetails.email}`}
                class="text-blue-600 dark:text-blue-400 font-semibold hover:underline break-all"
              >
                {companyDetails.email}
              </a>
            </div>
          </div>
        </div>

        <div
          class="bg-white dark:bg-neutral-800 rounded-2xl p-6 border border-neutral-200 dark:border-neutral-700 shadow-sm"
        >
          <div class="flex items-start gap-4">
            <div
              class="flex-shrink-0 w-12 h-12 bg-green-100 dark:bg-green-900/30 rounded-xl flex items-center justify-center text-green-600 dark:text-green-400"
            >
              <Icon name="mapPin" />
            </div>
            <div class="flex-1">
              <h3 class="font-bold text-neutral-900 dark:text-neutral-100 mb-1">
                Corporate Office Address:
              </h3>
              <p
                class="text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed"
              >
                {companyDetails.address}
              </p>
            </div>
          </div>
        </div>

        <div
          class="bg-gradient-to-br from-blue-500 to-blue-600 rounded-2xl p-6 text-white"
        >
          <h3 class="font-bold text-lg mb-2">Business Hours</h3>
          <div class="space-y-2 text-sm">
            <div class="flex justify-between">
              <span class="text-blue-100">Monday - Saturday</span>
              <span class="font-semibold">9:00 AM - 6:00 PM</span>
            </div>
            <div class="flex justify-between">
              <span class="text-blue-100">Sunday</span>
              <span class="font-semibold">Closed</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Contact Form -->
      <div class="lg:col-span-2">
        <div
          class="bg-white dark:bg-neutral-800 rounded-2xl p-8 lg:p-10 border border-neutral-200 dark:border-neutral-700 shadow-lg"
        >
          <div class="mb-8">
            <h2
              class="text-2xl font-bold text-neutral-900 dark:text-neutral-100 mb-2"
            >
              Send Us an Enquiry
            </h2>
            <p class="text-neutral-600 dark:text-neutral-400">
              Fill out the form below and our technical team will respond within
              24 hours.
            </p>
          </div>

          <form id="contact-enquiry-form" class="space-y-6">
            <!-- Personal Details -->
            <div class="space-y-4">
              <h3
                class="text-sm font-semibold text-neutral-700 dark:text-neutral-300 uppercase tracking-wider flex items-center gap-2"
              >
                <span
                  class="w-6 h-6 bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 rounded-full flex items-center justify-center text-xs font-bold"
                  >1</span
                >
                Personal Information
              </h3>

              <TextInput id="contact-name" label="Full Name" name="name" />

              <div class="grid sm:grid-cols-2 gap-4">
                <EmailContactInput id="contact-email" />
                <PhoneInput id="contact-phone" />
              </div>
            </div>

            <!-- Company Details -->
            <div
              class="space-y-4 pt-4 border-t border-neutral-200 dark:border-neutral-700"
            >
              <h3
                class="text-sm font-semibold text-neutral-700 dark:text-neutral-300 uppercase tracking-wider flex items-center gap-2"
              >
                <span
                  class="w-6 h-6 bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 rounded-full flex items-center justify-center text-xs font-bold"
                  >2</span
                >
                Company Information
              </h3>

              <div class="grid sm:grid-cols-2 gap-4">
                <TextInput
                  id="contact-company"
                  label="Company Name"
                  name="company"
                />
                <SelectInput
                  id="contact-company-type"
                  label="Company Type"
                  name="company_type"
                  options={[
                    { value: "", label: "Select type" },
                    { value: "epc-contractor", label: "EPC Contractor" },
                    { value: "manufacturer", label: "Manufacturer" },
                    { value: "distributor", label: "Distributor / Dealer" },
                    { value: "end-user", label: "End User / Project Owner" },
                    { value: "consultant", label: "Consultant / Engineer" },
                    { value: "government", label: "Government / PSU" },
                    { value: "other", label: "Other" },
                  ]}
                />
              </div>
            </div>

            <!-- Location -->
            <div
              class="space-y-4 pt-4 border-t border-neutral-200 dark:border-neutral-700"
            >
              <h3
                class="text-sm font-semibold text-neutral-700 dark:text-neutral-300 uppercase tracking-wider flex items-center gap-2"
              >
                <span
                  class="w-6 h-6 bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 rounded-full flex items-center justify-center text-xs font-bold"
                  >3</span
                >
                Project Location
              </h3>

              <div class="grid sm:grid-cols-2 gap-4">
                <TextInput id="contact-city" label="City" name="city" />
                <TextInput
                  id="contact-state"
                  label="State / Province"
                  name="state"
                />
              </div>

              <div>
                <SelectInput
                  id="contact-country"
                  label="Country"
                  name="country"
                  options={[
                    { value: "", label: "Select country" },
                    { value: "IN", label: "India" },
                    { value: "AE", label: "UAE" },
                    { value: "SA", label: "Saudi Arabia" },
                    { value: "QA", label: "Qatar" },
                    { value: "OM", label: "Oman" },
                    { value: "BD", label: "Bangladesh" },
                    { value: "LK", label: "Sri Lanka" },
                    { value: "NP", label: "Nepal" },
                    { value: "OTHER", label: "Other" },
                  ]}
                />
                <input
                  type="text"
                  id="contact-country-other"
                  name="country_other"
                  placeholder="Please specify country"
                  class="hidden mt-2 block w-full rounded-lg border border-neutral-200 bg-neutral-50 px-4 py-3 text-sm text-neutral-700 placeholder:text-neutral-500 focus:border-blue-500 focus:outline-hidden focus:ring-2 focus:ring-blue-500/20 dark:border-neutral-600 dark:bg-neutral-700/30 dark:text-neutral-300 dark:placeholder:text-neutral-400"
                />
              </div>
            </div>

            <!-- Requirements -->
            <div
              class="space-y-4 pt-4 border-t border-neutral-200 dark:border-neutral-700"
            >
              <h3
                class="text-sm font-semibold text-neutral-700 dark:text-neutral-300 uppercase tracking-wider flex items-center gap-2"
              >
                <span
                  class="w-6 h-6 bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 rounded-full flex items-center justify-center text-xs font-bold"
                  >4</span
                >
                Project Requirements
              </h3>

              <div class="grid sm:grid-cols-2 gap-4">
                <SelectInput
                  id="contact-product"
                  label="Product / Service Required"
                  name="product"
                  options={[
                    { value: "", label: "Select product/service" },
                    {
                      value: "thermal-spray-wires",
                      label: "Thermal Spray Wires",
                    },
                    {
                      value: "thermal-spray-powders",
                      label: "Thermal Spray Powders",
                    },
                    {
                      value: "spray-equipment",
                      label: "Spray Equipment & Machinery",
                    },
                    {
                      value: "spare-parts",
                      label: "Spare Parts & Consumables",
                    },
                    {
                      value: "anti-corrosion",
                      label: "Anti-Corrosion Coatings",
                    },
                    {
                      value: "wear-resistance",
                      label: "Wear Resistance Coatings",
                    },
                    {
                      value: "surface-restoration",
                      label: "Surface Restoration",
                    },
                    { value: "other-custom", label: "Other / Custom Solution" },
                  ]}
                />
                <TextInput
                  id="contact-quantity"
                  label="Estimated Quantity (Optional)"
                  name="quantity"
                />
              </div>

              <TextAreaInput
                id="contact-message"
                label="Project Details / Special Requirements"
                name="message"
              />
            </div>

            <div class="pt-6 space-y-4">
              <div id="form-status" class="hidden text-sm font-semibold"></div>

              <AuthBtn title="Send Enquiry" />

              <p
                class="text-xs text-center text-neutral-500 dark:text-neutral-400"
              >
                By submitting this form, you agree to our privacy policy. We'll
                respond within 24 hours.
              </p>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Form Handler Script -->
<script>
  const form = document.getElementById(
    "contact-enquiry-form"
  ) as HTMLFormElement | null;
  const statusEl = document.getElementById("form-status") as
    | HTMLElement
    | null;
  const countrySelect = document.getElementById(
    "contact-country"
  ) as HTMLSelectElement | null;
  const countryOtherInput = document.getElementById(
    "contact-country-other"
  ) as HTMLInputElement | null;

  // Show/hide custom country input
  countrySelect?.addEventListener("change", (e) => {
    const target = e.target;
    if (target && target instanceof HTMLSelectElement) {
      if (target.value === "OTHER") {
        countryOtherInput?.classList.remove("hidden");
      } else {
        countryOtherInput?.classList.add("hidden");
        if (countryOtherInput) countryOtherInput.value = "";
      }
    }
  });

  // Form submission
  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!statusEl || !form) return;

    const status = statusEl as HTMLElement;
    const sendTo = "gansh3764@gmail.com";

    status.classList.remove("text-green-600", "text-red-600", "hidden");
    status.classList.add("text-neutral-500");
    status.innerText = "⏳ Sending your enquiry...";

    const formData = new FormData(form as HTMLFormElement);

    // Handle custom country
    let countryValue = formData.get("country") || "";
    if (countryValue === "OTHER") {
      const other = formData.get("country_other");
      countryValue = other ? String(other) : "";
    }

    const quantity = formData.get("quantity") || "";
    const originalMessage = formData.get("message") || "";

    const emailValue = String(formData.get("hs-email-contacts") || "");
    const phoneValue = String(formData.get("hs-phone-number") || "");

    const fullMessage = [
      `Name: ${String(formData.get("name") || "")}`,
      `Email: ${emailValue}`,
      `Phone: ${phoneValue}`,
      `Company: ${String(formData.get("company") || "")}`,
      `Company Type: ${String(formData.get("company_type") || "")}`,
      `City: ${String(formData.get("city") || "")}`,
      `State: ${String(formData.get("state") || "")}`,
      `Country: ${String(countryValue)}`,
      `Product / Service: ${String(formData.get("product") || "")}`,
      `Quantity: ${String(quantity)}`,
      "Message:",
      String(originalMessage),
    ].join("\n");

    
const htmlMessage = `
<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8" />
<style>
  body{
    font-family: Arial, Helvetica, sans-serif;
    background:#f4f6f9;
    margin:0;
    padding:20px;
  }

  .container{
    max-width:700px;
    margin:auto;
    background:#ffffff;
    border-radius:12px;
    overflow:hidden;
    box-shadow:0 4px 15px rgba(0,0,0,0.08);
  }

  .header{
    background:linear-gradient(135deg,#0f172a,#1e3a8a);
    color:#fff;
    padding:25px;
  }

  .badge{
    display:inline-block;
    background:#22c55e;
    color:#fff;
    padding:8px 14px;
    border-radius:30px;
    font-size:12px;
    font-weight:bold;
    letter-spacing:1px;
  }

  .title{
    margin-top:15px;
    font-size:28px;
    font-weight:700;
  }

  .subtitle{
    color:#dbeafe;
    margin-top:6px;
  }

  .content{
    padding:25px;
  }

  .alert{
    background:#ecfdf5;
    border-left:5px solid #22c55e;
    padding:15px;
    border-radius:8px;
    margin-bottom:25px;
  }

  .alert strong{
    color:#166534;
  }

  table{
    width:100%;
    border-collapse:collapse;
    margin-top:10px;
  }

  td{
    padding:12px;
    border-bottom:1px solid #e5e7eb;
    vertical-align:top;
  }

  td:first-child{
    width:180px;
    font-weight:600;
    color:#475569;
    background:#f8fafc;
  }

  .message-box{
    background:#f8fafc;
    border:1px solid #e2e8f0;
    border-radius:10px;
    padding:15px;
    margin-top:20px;
    line-height:1.7;
  }

  .footer{
    background:#f8fafc;
    padding:20px;
    text-align:center;
    font-size:13px;
    color:#64748b;
  }

  .priority{
    color:#dc2626;
    font-weight:700;
  }

  .contact-btn{
    display:inline-block;
    margin-top:15px;
    padding:10px 18px;
    background:#2563eb;
    color:#fff !important;
    text-decoration:none;
    border-radius:8px;
    font-weight:600;
  }
</style>
</head>

<body>

<div class="container">

  <div class="header">
    <span class="badge">🔥 NEW LEAD RECEIVED</span>

    <div class="title">
      Mfolks Geotrix Lead Notification
    </div>

    <div class="subtitle">
      A new customer enquiry has been submitted through your website.
    </div>
  </div>

  <div class="content">

    <div class="alert">
      <strong>Action Required:</strong>
      Please contact this lead as soon as possible.
      <span class="priority">High Response Rate Within 24 Hours</span>
    </div>

    <table>
      <tr>
        <td>Lead Name</td>
        <td>${String(formData.get("name") || "")}</td>
      </tr>

      <tr>
        <td>Email Address</td>
        <td>${emailValue}</td>
      </tr>

      <tr>
        <td>Phone Number</td>
        <td>${phoneValue}</td>
      </tr>

      <tr>
        <td>Company Name</td>
        <td>${String(formData.get("company") || "")}</td>
      </tr>

      <tr>
        <td>Company Type</td>
        <td>${String(formData.get("company_type") || "")}</td>
      </tr>

      <tr>
        <td>City</td>
        <td>${String(formData.get("city") || "")}</td>
      </tr>

      <tr>
        <td>State</td>
        <td>${String(formData.get("state") || "")}</td>
      </tr>

      <tr>
        <td>Country</td>
        <td>${String(countryValue)}</td>
      </tr>

      <tr>
        <td>Interested Product</td>
        <td>${String(formData.get("product") || "")}</td>
      </tr>

      <tr>
        <td>Estimated Quantity</td>
        <td>${String(quantity)}</td>
      </tr>
    </table>

    <div class="message-box">
      <strong>Customer Requirement:</strong><br><br>
      ${String(originalMessage).replace(/\n/g, "<br/>")}
    </div>

    <a href="mailto:${emailValue}" class="contact-btn">
      Reply to Lead
    </a>

  </div>

  <div class="footer">
    <strong>Mfolks Geotrix CRM Notification</strong><br>
    Generated automatically from Website Contact Form.<br>
    Time: ${new Date().toLocaleString()}
  </div>

</div>

</body>
</html>
`;



    const payload = {
      to: sendTo,
     subject: `🔥 NEW LEAD | ${formData.get("name")} | ${formData.get("product") || "General Enquiry"}`,
      recipientName: String(formData.get("name") || "Valued Guest"),
      useTemplate: false,
      email: emailValue,
      phone: phoneValue,
      text: fullMessage,
      html: htmlMessage,
    };

    try {
      const response = await fetch("https://geotrix-mail-backend.vercel.app/send-email", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify(payload),
      });

      const result = await response.json();

      if (response.ok) {
        status.innerText =
          "✅ Success! Your enquiry has been received. We'll respond within 24 hours.";
        status.classList.replace("text-neutral-500", "text-green-600");
        (form as HTMLFormElement).reset();
      } else {
        throw new Error(result?.message || "Submission failed");
      }
    } catch (err) {
      console.error(err);
      status.innerText =
        "❌ Error sending enquiry. Please try again or call us directly.";
      status.classList.replace("text-neutral-500", "text-red-600");
    }
  });
</script>